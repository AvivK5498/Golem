# Required
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Optional: Voice transcription (Groq Whisper API — free tier)
# GROQ_API_KEY=gsk_your-groq-api-key

# Optional: Telegram bot token (can also be configured via the UI)
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Optional: Custom data/skills directories
# GOLEM_DATA_DIR=./data
# GOLEM_SKILLS_DIR=./skills

# Optional: Remote logging endpoint
# LOGGER_URL=https://your-logging-service.com
# LOGGER_TOKEN=your-logger-token

# Optional: Webhook authentication
# GOLEM_WEBHOOK_TOKEN=your-webhook-token

# Optional: Brave Search (for MCP brave-search server)
# BRAVE_API_KEY=your-brave-api-key
